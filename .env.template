# ─────────────────────────────────────────────────────────────────────────────
# IYKYK GAMES — Environment Variable Template
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_NAME=iykyk-games

# ─── Backend (FastAPI) ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true                    # set false in production
SECRET_KEY=your-secret-key-here        # generate: openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:3000  # comma-separated in production

# ─── Frontend (React + Vite) ─────────────────────────────────────────────────
# Vite exposes env vars with VITE_ prefix
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=IYKYK Games

# ─── AI / Agentic Workflows ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here     # optional fallback

# ─── Database (future use) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/iykyk_games

# ─── Redis (future: session/cache) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Supabase (optional) ─────────────────────────────────────────────────────
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
