# ─────────────────────────────────────────────────────────────────────────────
# IYKYK GAMES — Environment Variable Template
# Copy this file to .env (and backend/.env) and fill in real values.
# Never commit .env files.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_NAME=iykyk-games

# ─── Backend (FastAPI) ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true                    # set false in production
SECRET_KEY=your-secret-key-here        # generate: openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:3000  # comma-separated in production

# ─── Supabase (backend only — service role key, never exposed to browser) ────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI / Agentic Workflows ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here     # optional fallback

# ─── Frontend (React + Vite) — set these in Vercel project env vars ──────────
# VITE_ prefix is required for Vite to expose vars to the browser
VITE_API_URL=http://localhost:8000           # REST API base URL
VITE_WS_URL=ws://localhost:8000             # WebSocket base URL
# In production:
# VITE_API_URL=https://your-backend.railway.app
# VITE_WS_URL=wss://your-backend.railway.app

# ─── Database (future use) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/iykyk_games

# ─── Redis (future: session/cache) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
